{
  "info": {
    "name": "Airbnb Clone API",
    "description": "Complete API collection for Airbnb Clone backend",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api" },
    { "key": "accessToken", "value": "" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\",\n  \"phone\": \"+1234567890\",\n  \"role\": \"user\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@demo.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Login as Host",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"host@demo.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/auth/me"
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/logout"
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/refresh-token"
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/users/profile"
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/users/profile",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Name\",\n  \"phone\": \"+9876543210\"\n}"
            }
          }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/users/change-password",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"currentPassword\": \"password123\",\n  \"newPassword\": \"newpass456\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Properties",
      "item": [
        {
          "name": "Get All Properties",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/properties?page=1&limit=12&sort=newest",
              "host": ["{{baseUrl}}"],
              "path": ["properties"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "12" },
                { "key": "sort", "value": "newest" },
                { "key": "search", "value": "", "disabled": true },
                { "key": "minPrice", "value": "", "disabled": true },
                { "key": "maxPrice", "value": "", "disabled": true },
                { "key": "guests", "value": "", "disabled": true },
                { "key": "bedrooms", "value": "", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Get Single Property",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/properties/:id"
          }
        },
        {
          "name": "Create Property",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/properties",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Beautiful Test Property\",\n  \"description\": \"A wonderful property for testing.\",\n  \"location\": {\n    \"country\": \"India\",\n    \"state\": \"Maharashtra\",\n    \"city\": \"Mumbai\",\n    \"address\": \"123 Marine Drive\"\n  },\n  \"pricePerNight\": 100,\n  \"maxGuests\": 4,\n  \"bedrooms\": 2,\n  \"bathrooms\": 1,\n  \"amenities\": [\"WiFi\", \"Air Conditioning\", \"Kitchen\"],\n  \"images\": [\"https://images.unsplash.com/photo-1564013799919-ab600027ffc6?w=800\"]\n}"
            }
          }
        },
        {
          "name": "My Listings",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/properties/my-listings"
          }
        },
        {
          "name": "Delete Property",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/properties/:id"
          }
        }
      ]
    },
    {
      "name": "Bookings",
      "item": [
        {
          "name": "Create Booking",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/bookings",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"propertyId\": \"PROPERTY_ID_HERE\",\n  \"checkIn\": \"2025-03-01\",\n  \"checkOut\": \"2025-03-05\",\n  \"guests\": 2\n}"
            }
          }
        },
        {
          "name": "My Bookings",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/bookings/my"
          }
        },
        {
          "name": "Host Bookings",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/bookings/host"
          }
        },
        {
          "name": "Cancel Booking",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/bookings/:id/cancel"
          }
        },
        {
          "name": "Get Booked Dates",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/bookings/property/:propertyId/dates"
          }
        }
      ]
    },
    {
      "name": "Reviews",
      "item": [
        {
          "name": "Create Review",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/reviews",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"propertyId\": \"PROPERTY_ID_HERE\",\n  \"rating\": 5,\n  \"comment\": \"Amazing place! Loved every moment.\"\n}"
            }
          }
        },
        {
          "name": "Get Property Reviews",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/reviews/:propertyId"
          }
        }
      ]
    },
    {
      "name": "Wishlist",
      "item": [
        {
          "name": "Add to Wishlist",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/wishlist/add",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"propertyId\": \"PROPERTY_ID_HERE\"\n}"
            }
          }
        },
        {
          "name": "Remove from Wishlist",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/wishlist/remove",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"propertyId\": \"PROPERTY_ID_HERE\"\n}"
            }
          }
        },
        {
          "name": "My Wishlist",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/wishlist/my"
          }
        }
      ]
    }
  ]
}
